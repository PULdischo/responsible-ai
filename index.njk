---
layout: default
aboutEvent: Responsible AI is a series of workshops that will introduce you to the basics of AI and how it can be used in scholarly research. 
---
<!-- ======= Hero Section ======= -->
<section id="hero">
  <div style="overflow:hidden;">
          <iframe style="width:100%; height: 100vh; position:absolute; z-index: 2; opacity: 0.1;" src="https://alteredqualia.com/xg/examples/abstract_mountains.html" frameborder="0"></iframe>
          <!-- Visualization by Amanda Ghassaei, https://amandaghassaei.com/   -->
    <div class="hero-container" >
    <img height="150" src="/assets/img/noun-sparkles-7598231-00449F.png" / >
    <h2 class="mb-4 pb-0" style="color: black;">Responsible AI</h2>
    <a target="_blank" href="#schedule" class="about-btn scrollto">Schedule</a>
    
    <h4 style="color:black;">A series of workshops and collaborative sessions where<br> researchers can learn about recent developments<br> in generative AI. </h4>
   
    </div>
  </div>
  
 
</section><!-- End Hero Section -->
 
 
<main id="main">
 

  <!-- ======= Schedule Section ======= -->
    <section id="schedule" class="section-with-bg">
      <div class="container" data-aos="fade-up">
        <div class="section-header">
          <h2>Schedule</h2>
          <p>The AY 2025–26 workshop series on multimodal generative AI is now complete — browse the materials in the <a href="#archive" class="scrollto">Past Sessions</a> archive below. We'll return in fall 2026 with a new series for AY 2026–27.</p>
        </div>

        
        
        <div class="row justify-content-center" data-aos="fade-up" data-aos-delay="200">
          <div class="col-lg-9">

            
            <!-- AY 2026–27 placeholder -->
            <div class="row schedule-item" style="opacity: 0.55;">
              <div class="col-md-2"><time>Fall 2026</time></div>
              <div class="col-md-10">
                <h4>AY 2026–27 series <span>— coming soon</span></h4>
                <p>New sessions will be announced in fall 2026. Topics and dates to be confirmed.</p>
              </div>
            </div>

          </div>
        </div>

      </div>

    </section><!-- End Schedule Section -->

  <!-- ======= Archive Section ======= -->
  <section id="archive">
    <div class="container" data-aos="fade-up">
      <div class="section-header">
        <h2>Past Sessions</h2>
        <p>Browse notebooks, slides, and other materials from previous workshops. Each session includes a read-only preview, a one-click link to run the notebook in Google Colab, and a portable version you can run in any Jupyter environment.</p>
      </div>

      {% if archive and archive.length %}
        <div class="row justify-content-center" data-aos="fade-up" data-aos-delay="200">
          <div class="col-lg-9">
            {% for session in archive %}
            <div class="row schedule-item">
              <div class="col-md-2">
                <time>{{ session.time }}</time>
              </div>
              <div class="col-md-10">
                <h4>{{ session.title }}</h4>
                <p>{{ session.description }}</p>
                {% if session.tags %}
                <div>
                  {% for tag in session.tags %}
                  <span class="archive-tag">{{ tag }}</span>
                  {% endfor %}
                </div>
                {% endif %}
                <div class="archive-materials">
                  {% for material in session.materials %}
                  <a href="{{ material.url }}" target="_blank" rel="noopener">
                    <button type="button" class="btn btn-outline-secondary btn-sm">
                      {% if material.icon %}<i class="bi {{ material.icon }}"></i> {% endif %}{{ material.label }}
                    </button>
                  </a><br>
                  {% endfor %}
                </div>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <p class="text-center text-muted">Past session materials will appear here after each workshop.</p>
      {% endif %}

    </div>
  </section><!-- End Archive Section -->

<section id="venue" class="venue section">

      <!-- Section Title -->
      <div class="container section-title aos-init aos-animate" data-aos="fade-up">
        <h2>Location<br></h2>
      </div><!-- End Section Title -->

      <div class="container-fluid aos-init aos-animate" data-aos="fade-up">

        <div class="row g-0">
          <div class="col-lg-6 venue-map">
          <iframe src="https://campusmap.princeton.edu/?poiIdViaMap=5947" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>

          <div class="col-lg-6 venue-info">
            <div class="row justify-content-center">
              <div class="col-11 col-lg-8 position-relative">
                <h3>Commons Library Classroom (D112)</h3>
                <p></p>
                <div >
            <div class="venue-gallery">
              <a href="" class="glightbox" data-gall="venue-gallery">
                <img src="https://library.princeton.edu/sites/g/files/toruqf6021/files/styles/16x9_750w_422h/public/2025-07/20250729_brj_commonsempty_0010.jpg?itok=p3r0UEW7" alt="" class="img-fluid">
              </a>
            </div>
          </div>
              </div>
            </div>
          </div>
        </div>

      </div>

     
      

    </section>
